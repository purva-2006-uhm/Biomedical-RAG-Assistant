# Copy this file to .env and fill in your own keys.
# Never commit real secrets.

# LLM Provider: nvidia or groq
LLM_PROVIDER=nvidia

# NVIDIA settings (required when LLM_PROVIDER=nvidia)
NVIDIA_API_KEY=your_nvidia_api_key_here
LLM_BASE_URL=https://integrate.api.nvidia.com/v1

# Groq settings (required when LLM_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here

# LLM behavior
LLM_MODEL=openai/gpt-oss-120b
LLM_MAX_OUTPUT_TOKENS=2048
LLM_TIMEOUT_SECONDS=30
LLM_CONTEXT_WINDOW=12000
LLM_TEMPERATURE=0.2
LLM_MAX_RETRIES=2
LLM_RESPONSE_MODE=structured_reasoning
